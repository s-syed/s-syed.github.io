 ","targetRectangle":{"y":370.66860961914062,"x":62.764708280563354,"width":75.372000000000014,"height":26.361846923828125}},{"text":"Both MALA and RMW lack memory to maintain a persistent direction of travel","targetRectangle":{"y":599.64914905847775,"x":62.764708284637209,"width":731.32399999999996,"height":26.361846923828125}},{"text":"Still behaves like a random walk in the high-probability directions","targetRectangle":{"y":540.41790109598855,"x":97.76470825585335,"width":607.15599999999995,"height":26.361846923828125}},{"text":"Additionaly required tuning the step size ￼","targetRectangle":{"y":485.15887615612144,"x":97.764708271263714,"width":394.56013084112141,"height":31.721952634437116}},{"text":"equation.pdf","targetRectangle":{"y":485.15887615612144,"x":480.38870827126362,"width":11.936130841121496,"height":31.721952634437116}},{"text":"Gradient probes the local geometry of the target and identifies optimal directions to traverse","targetRectangle":{"y":448.70779004202024,"x":97.764708209622199,"width":864.3359999999999,"height":26.361846923828125}},{"text":"Can probe target pointwise","targetRectangle":{"y":212.36175763430012,"x":97.764708280563354,"width":257.1579999999999,"height":26.361846923828125}},{"text":"Behaves like a random walk in all directions","targetRectangle":{"y":295.38892963338242,"x":97.764708209622171,"width":409.15599999999984,"height":26.361846923828125}},{"text":"equation.pdf","targetRectangle":{"y":385.44635009765625,"x":287.78851318359375,"width":448.42300363929837,"height":30.800000000000011}},{"text":"￼","targetRectangle":{"y":66.408382415771484,"x":964.57660043239594,"width":23.0390625,"height":28}},{"text":"equation.pdf","targetRectangle":{"y":251.54696167967882,"x":347.97070842129369,"width":14.80687174609443,"height":28.000000339140627}},{"text":"MALA vs RMW","targetRectangle":{"y":56.908382415771484,"x":36,"width":216,"height":48.400146484375}},{"text":"Only requires tuning noise ￼","targetRectangle":{"y":251.546961679678