6637345,"height":33.10659872037229}},{"text":"In the context of sampling, we are given unnormalised densities:","targetRectangle":{"y":175.36903381347656,"x":62.764708280563354,"width":604.29600000000005,"height":26.361846923828125}},{"text":"equation.pdf","targetRectangle":{"y":127.38838195800781,"x":843.65182977588995,"width":12.742626168224319,"height":31.896855729718084}},{"text":"equation.pdf","targetRectangle":{"y":211.31498718261719,"x":433.7984619140625,"width":156.40308550727946,"height":53.274996407330036}},{"text":"Normalinging constants ￼ satisfies ￼ and ￼","targetRectangle":{"y":460.1917724609375,"x":97.764708280563354,"width":573.65291544557908,"height":28.125821268854565}},{"text":"equation.pdf","targetRectangle":{"y":400.37478637695312,"x":591.19982044262611,"width":65.71378624112333,"height":33.373817505419026}},{"text":"equation.pdf","targetRectangle":{"y":460.31759306523759,"x":327.57670828056331,"width":42.768613922171426,"height":28.000000664554477}},{"text":"There is a lot of flexibility in choosing a path. We will study what makes for a good path later.","targetRectangle":{"y":517.3377685546875,"x":62.764708280563354,"width":868.40599999999961,"height":26.361846923828125}},{"text":"How to construct an annealing path","targetRectangle":{"y":56.908382415771484,"x":36,"width":602.976,"height":48.400146484375}},{"text":"equation.pdf","targetRectangle":{"y":127.38838195800781,"x":742.89470828056301,"width":13.549121495327086,"height":31.721952634437059}},{"text":"equation.pdf","targetRectangle":{"y":460.1917724609375,"x":587.84506205275488,"width":83.572561673387554,"height":28.000000339140627}},{"text":"equation.pdf","targetRectangle":{"y":320.90713500976562,"x":343.39688110351562,"width":337.20626175154212,"height":64.919999894201737}},{"text":"equation.pdf","targetRectangle":{"y":400.37478637695312,"x":97.764708280563354,"width":122.71311216206294,"height":37.019445215699363}}],"baseLayer":{"animations":[],"initialState":{"affineTransform":[1,0,