99999996,"height":26.449798583984375}},{"text":"Design choices traditionally appeal towards stability over flexibility","targetRectangle":{"y":623.4552001953125,"x":107.76470828056335,"width":614.85599999999999,"height":26.361846923828125}},{"text":"equation.pdf","targetRectangle":{"y":434.7628173828125,"x":807.13422229925493,"width":7.4735233644860273,"height":31.950622084858253}},{"text":"Each have their own pros and cons and measure different things","targetRectangle":{"y":479.92251586914062,"x":107.76470828056335,"width":608.45399999999984,"height":26.361846923828125}},{"text":"Extremely problem-specific","targetRectangle":{"y":250.65611267089844,"x":107.76470828056335,"width":255.48599999999999,"height":26.361846923828125}},{"text":"equation.pdf","targetRectangle":{"y":150.118408203125,"x":411.34799194335938,"width":201.30399645876832,"height":36.195247842594995}},{"text":"Challenge 3: In general, the optimisations can be fragile with limited target information","targetRectangle":{"y":545.447021484375,"x":72.764708280563354,"width":818.17999999999972,"height":26.449798583984375}},{"text":"Challenge 2: How do you choose the discrepancy ￼?","targetRectangle":{"y":393.99627685546875,"x":72.764708280563354,"width":517.96230993698737,"height":28.000000339140627}},{"text":"Challenges with Variational inference","targetRectangle":{"y":56.908382415771484,"x":36,"width":645.88799999999992,"height":48.400146484375}},{"text":"Eg. Total variation, forward\/reverse KL, Wasserstein, MMD, ￼-divergence, ￼-divergence, etc","targetRectangle":{"y":434.7628173828125,"x":107.76470828056335,"width":860.09503738317756,"height":31.950622084858253}},{"text":"equation.pdf","targetRectangle":{"y":434.7628173828125,"x":668.39070828056333,"width":14.839514018691602,"height":31.721952634437059}},{"text":"￼","targetRectangle":{"y":66.408382415771484,"x":964.57660043239594,"width":23.0390625,"height":28}},{"text":"equation.pdf","targetRectangle":{"y":393.99627685546875,"x":561.7807082805632,"