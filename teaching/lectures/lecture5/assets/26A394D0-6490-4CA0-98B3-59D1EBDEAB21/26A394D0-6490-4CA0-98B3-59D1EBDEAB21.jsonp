25000000000023,"height":22.375}},{"text":"Variational inference","targetRectangle":{"y":56.908382415771484,"x":36,"width":361.584,"height":48.400146484375}},{"text":"equation.pdf","targetRectangle":{"y":291.86834379765946,"x":553.83210469087044,"width":11.185853057172267,"height":28.000000664554477}},{"text":"Given a divergence ￼ and a reference ￼ and target ￼","targetRectangle":{"y":121.56064605712891,"x":62.764708280563354,"width":496.00755940446675,"height":28.125821268854565}},{"text":"Let ￼ be a variational family of reference distribution","targetRectangle":{"y":553.22637939453125,"x":72.764708280563354,"width":621.24622647476804,"height":33.621949234390968}},{"text":"equation.pdf","targetRectangle":{"y":121.68646666142901,"x":426.39701821755085,"width":11.185853057172267,"height":28.000000664554463}},{"text":"equation.pdf","targetRectangle":{"y":506.20166015625,"x":495.82827758789062,"width":19.390118627368906,"height":17.470248958691968}},{"text":"￼","targetRectangle":{"y":66.408382415771484,"x":964.57660043239594,"width":23.0390625,"height":28}},{"text":"equation.pdf","targetRectangle":{"y":508.70166015625,"x":775.51251220703125,"width":12.924999229609966,"height":11.149999335408211}},{"text":"The choice of reference is crutial","targetRectangle":{"y":246.18960571289062,"x":72.764708280563354,"width":304.89799999999997,"height":26.361846923828125}},{"text":"equation.pdf","targetRectangle":{"y":607.1090087890625,"x":378.78470828056334,"width":18.603158878504701,"height":31.721952634437116}},{"text":"We can efficiently estimate ￼ using the reference ￼ if and only if  ￼ is small","targetRectangle":{"y":291.74252319335938,"x":92.764708280563354,"width":746.17431588556087,"height":28.125821268854565}},{"text":"Goal: Find the best reference in ￼ that approximages the target","targetRectangle":{"y":607.1090087890625,"x":72.764708280563354,"width":604.17715887850443,"height":31.721952634437116}},{"text":"equation.pdf","targetRectangle":{"y":478.06228637695312,"x":5